<?xml version="1.0" encoding="UTF-8"?>
<launch>

    <let name="rviz_config" value="$(find-pkg-share vins)/config/vins_rviz_config.rviz"/>

    <!-- Connect VINS body, which is camera_imu_optical_frame, to the RealSense camera_link tree. -->
    <node name="d435i_body_to_camera_link"
          pkg="tf2_ros"
          exec="static_transform_publisher"
          args="--x -0.00552 --y 0.00510 --z 0.01174 --qx 0.5 --qy -0.5 --qz 0.5 --qw 0.5 --frame-id body --child-frame-id camera_link"/>

    <node name="rviz2" pkg="rviz2" exec="rviz2" args="-d $(var rviz_config)"/>

</launch>
